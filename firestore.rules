rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && 
                    isValidUser(request.resource.data) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fullName', 'phone', 'address', 'city', 'state', 'zipCode', 'updatedAt']);
    }
  }
}
